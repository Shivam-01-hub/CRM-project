# Partnership CRM — Backend Environment Variables (Example)
# ==========================================================
# Copy this file to .env and adjust values as needed.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/partnership_crm"

# JWT secret for signing access tokens (change in production!)
JWT_ACCESS_SECRET="change-me-to-a-random-secret-in-production"

# JWT token time-to-live (e.g. 1h, 7d, 30d)
JWT_ACCESS_TTL="1h"

# Backend server port
PORT=4000

# Comma-separated list of allowed CORS origins
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
